<interface>
  <object class="BobguiShortcutsWindow" id="help_overlay">
    <child>
      <object class="BobguiShortcutsSection">
        <child>
          <object class="BobguiShortcutsGroup">
            <property name="title">General</property>
            <child>
              <object class="BobguiShortcutsShortcut">
                <property name="accelerator">F1</property>
                <property name="title">Show About Dialog</property>
              </object>
            </child>
            <child>
              <object class="BobguiShortcutsShortcut">
                <property name="accelerator">&lt;Control&gt;q</property>
                <property name="title">Quit</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
