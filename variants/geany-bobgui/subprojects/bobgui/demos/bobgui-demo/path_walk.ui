<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <object class="BobguiWindow" id="window">
    <property name="title" translatable="yes">World Map</property>
    <property name="titlebar">
      <object class="BobguiHeaderBar">
        <child type="end">
          <object class="BobguiSpinButton">
            <property name="adjustment">
              <object class="BobguiAdjustment" id="adjustment">
                <property name="lower">0</property>
                <property name="upper">5000</property>
                <property name="value">500</property>
                <property name="step-increment">1</property>
                <property name="page-increment">10</property>
              </object>
            </property>
          </object>
        </child>
      </object>
    </property>
    <property name="child">
      <object class="BobguiBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="BobguiPathWalk" id="view">
            <property name="n-points" bind-source="adjustment" bind-property="value"/>
            <property name="hexpand">true</property>
            <property name="vexpand">true</property>
          </object>
        </child>
      </object>
    </property>
  </object>
</interface>
