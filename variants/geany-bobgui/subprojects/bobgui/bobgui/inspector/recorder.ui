<interface domain="bobgui40">
  <object class="BobguiSingleSelection" id="selection">
    <signal name="notify::selected" handler="recording_selected"/>
    <property name="model">
      <object class="GListStore" id="recordings"/>
    </property>
  </object>
  <template class="BobguiInspectorRecorder" parent="BobguiWidget">
    <child>
      <object class="BobguiBox" id="box">
        <property name="orientation">vertical</property>
        <child>
          <object class="BobguiBox">
            <style>
              <class name="toolbar"/>
            </style>
            <child>
              <object class="BobguiMenuButton">
                <property name="child">
                  <object class="BobguiImage">
                    <property name="paintable">
                      <object class="BobguiSvg">
                        <property name="resource">/org/bobgui/libbobgui/icons/open-menu-symbolic.svg</property>
                      </object>
                    </property>
                  </object>
                </property>
                <property name="tooltip-text" translatable="yes">Recording Options</property>
                <property name="menu-model">
                  <menu>
                    <item>
                      <attribute name="label" translatable="yes">Record events</attribute>
                      <attribute name="action">record.record-events</attribute>
                    </item>
                    <item>
                      <attribute name="label" translatable="yes">Add debug nodes</attribute>
                      <attribute name="action">record.debug-nodes</attribute>
                    </item>
                    <item>
                      <attribute name="label" translatable="yes">Highlight event sequences</attribute>
                      <attribute name="action">record.highlight-sequences</attribute>
                    </item>
                  </menu>
                </property>
              </object>
            </child>
            <child>
              <object class="BobguiToggleButton">
                <property name="child">
                  <object class="BobguiImage">
                    <property name="paintable">
                      <object class="BobguiSvg">
                        <property name="resource">/org/bobgui/libbobgui/icons/media-record-symbolic.svg</property>
                      </object>
                    </property>
                  </object>
                </property>
                <property name="tooltip-text" translatable="yes">Record frames</property>
                <property name="active" bind-source="BobguiInspectorRecorder" bind-property="recording" bind-flags="bidirectional|sync-create"/>
              </object>
            </child>
            <child>
              <object class="BobguiButton">
                <property name="child">
                  <object class="BobguiImage">
                    <property name="paintable">
                      <object class="BobguiSvg">
                        <property name="resource">/org/bobgui/libbobgui/icons/edit-clear-all-symbolic.svg</property>
                      </object>
                    </property>
                  </object>
                </property>
                <property name="tooltip-text" translatable="yes">Clear recorded frames</property>
                <signal name="clicked" handler="recordings_clear_all"/>
                <property name="hexpand">true</property>
                <property name="halign">start</property>
              </object>
            </child>
            <child>
              <object class="BobguiDropDown" id="rendering_mode_dropdown">
                <property name="sensitive">false</property>
                <property name="tooltip-text" translatable="yes">Profiling overlay (requires GSK_DEBUG=profile)</property>
                <property name="model">
                  <object class="BobguiStringList">
                    <!-- Keep in sync with enum in nodewrapper.h -->
                    <items>
                      <item>None</item>
                      <item>GPU times</item>
                      <item>Offscreens</item>
                      <item>Uploads</item>
                    </items>
                  </object>
                </property>
                <signal name="notify::selected" handler="rendering_mode_update"/>
              </object>
            </child>
            <child>
              <object class="BobguiToggleButton" id="dark_mode_button">
                <property name="child">
                  <object class="BobguiImage">
                    <property name="paintable">
                      <object class="BobguiSvg">
                        <property name="resource">/org/bobgui/libbobgui/icons/display-brightness-symbolic.svg</property>
                      </object>
                    </property>
                  </object>
                </property>
                <property name="tooltip-text" translatable="yes">Use a dark background</property>
                <property name="action-name">record.toggle-dark</property>
              </object>
            </child>
            <child>
              <object class="BobguiButton" id="render_node_save_button">
                <property name="sensitive">0</property>
                <property name="child">
                  <object class="BobguiImage">
                    <property name="paintable">
                      <object class="BobguiSvg">
                        <property name="resource">/org/bobgui/libbobgui/icons/document-save-as-symbolic.svg</property>
                      </object>
                    </property>
                  </object>
                </property>
                <property name="tooltip-text" translatable="yes">Save selected node</property>
                <signal name="clicked" handler="render_node_save"/>
              </object>
            </child>
            <child>
              <object class="BobguiButton" id="render_node_clip_button">
                <property name="sensitive">0</property>
                <property name="child">
                  <object class="BobguiImage">
                    <property name="paintable">
                      <object class="BobguiSvg">
                        <property name="resource">/org/bobgui/libbobgui/icons/edit-copy-symbolic.svg</property>
                      </object>
                    </property>
                  </object>
                </property>
                <property name="tooltip-text" translatable="yes">Copy to clipboard</property>
                <signal name="clicked" handler="render_node_clip"/>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="BobguiSeparator" />
        </child>
        <child>
          <object class="BobguiBox">
            <style>
              <class name="view"/>
            </style>
            <child>
              <object class="BobguiScrolledWindow">
                <property name="hscrollbar-policy">never</property>
                <property name="propagate-natural-width">1</property>
                <child>
                  <object class="BobguiListView" id="recordings_list">
                    <property name="vexpand">1</property>
                    <property name="model">selection</property>
                    <property name="tab-behavior">item</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="BobguiSeparator"/>
            </child>
            <child>
              <object class="BobguiStack" id="recording_data_stack">
                <child>
                  <object class="BobguiStackPage">
                    <property name="name">no_data</property>
                    <property name="child">
                      <object class="BobguiLabel">
                        <property name="label">No data.</property>
                        <property name="halign">center</property>
                        <property name="valign">center</property>
                      </object>
                    </property>
                  </object>
                </child>
                <child>
                  <object class="BobguiStackPage">
                    <property name="name">frame_data</property>
                    <property name="child">
                      <object class="BobguiPaned">
                        <property name="position">400</property>
                        <property name="wide-handle">1</property>
                        <child>
                          <object class="BobguiScrolledWindow">
                            <property name="propagate-natural-width">1</property>
                            <child>
                              <object class="BobguiListView" id="render_node_list">
                                <property name="vexpand">1</property>
                                <property name="hexpand">1</property>
                                <property name="tab-behavior">item</property>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="BobguiPaned" id="render_paned">
                            <property name="orientation">vertical</property>
                            <property name="position">200</property>
                            <property name="wide-handle">1</property>
                            <child>
                              <object class="BobguiScrolledWindow">
                                <property name="propagate-natural-width">1</property>
                                <child>
                                  <object class="BobguiColumnView" id="node_property_tree">
                                    <property name="tab-behavior">item</property>
                                    <style>
                                      <class name="data-table"/>
                                      <class name="list"/>
                                    </style>
                                    <child>
                                      <object class="BobguiColumnViewColumn">
                                        <property name="title" translatable="yes">Property</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiColumnViewColumn">
                                        <property name="title" translatable="yes">Value</property>
                                        <property name="expand">1</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="BobguiPicture" id="render_node_view">
                                <property name="hexpand">1</property>
                                <property name="vexpand">1</property>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>
                <child>
                  <object class="BobguiStackPage">
                    <property name="name">event_data</property>
                    <property name="child">
                      <object class="BobguiPaned">
                        <property name="position">400</property>
                        <property name="wide-handle">1</property>
                        <child>
                          <object class="BobguiScrolledWindow">
                            <property name="propagate-natural-width">1</property>
                            <child>
                              <object class="BobguiColumnView" id="event_property_tree">
                                <property name="tab-behavior">item</property>
                                <style>
                                  <class name="data-table"/>
                                  <class name="list"/>
                                </style>
                                <child>
                                  <object class="BobguiColumnViewColumn">
                                    <property name="title" translatable="yes">Property</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="BobguiColumnViewColumn">
                                    <property name="title" translatable="yes">Value</property>
                                    <property name="expand">1</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="BobguiPicture" id="event_view">
                            <property name="hexpand">1</property>
                            <property name="vexpand">1</property>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>

