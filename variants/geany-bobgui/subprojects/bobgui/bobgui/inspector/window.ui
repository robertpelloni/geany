<?xml version="1.0" encoding="UTF-8"?>
<interface domain="bobgui40">
  <object class="BobguiAdjustment" id="magnification_adjustment">
    <property name="lower">1.0</property>
    <property name="upper">5.0</property>
    <property name="page-increment">0.1</property>
    <property name="step-increment">0.1</property>
    <property name="value">2.0</property>
  </object>
  <template class="BobguiInspectorWindow" parent="BobguiWindow">
    <property name="default-height">500</property>
    <property name="default-width">800</property>
    <property name="titlebar">
      <object class="BobguiHeaderBar">
        <child>
          <object class="BobguiStack" id="button_stack">
            <property name="visible-child-name" bind-source="top_stack" bind-property="visible-child-name"/>
            <child>
              <object class="BobguiStackPage">
                <property name="name">objects</property>
                <property name="child">
                  <object class="BobguiBox">
                    <property name="spacing">6</property>
                    <child>
                      <object class="BobguiButton" id="select_object">
                        <property name="focus-on-click">0</property>
                        <property name="tooltip-text" translatable="yes">Select an Object</property>
                        <property name="halign">center</property>
                        <property name="valign">center</property>
                        <property name="child">
                          <object class="BobguiImage">
                            <property name="paintable">
                              <object class="BobguiSvg">
                                <property name="resource">/org/bobgui/libbobgui/icons/find-location-symbolic.svg</property>
                              </object>
                            </property>
                          </object>
                        </property>
                        <signal name="clicked" handler="bobgui_inspector_on_inspect"/>
                      </object>
                    </child>
                    <child>
                      <object class="BobguiStack" id="object_buttons">
                        <child>
                          <object class="BobguiStackPage">
                            <property name="name">list</property>
                            <property name="child">
                              <object class="BobguiButton" id="object_details_button">
                                <property name="focus-on-click">0</property>
                                <property name="tooltip-text" translatable="yes">Show Details</property>
                                <property name="halign">center</property>
                                <property name="valign">center</property>
                                <property name="child">
                                  <object class="BobguiImage">
                                    <property name="paintable">
                                      <object class="BobguiSvg" id="dialog-information-symbolic">
                                        <property name="resource">/org/bobgui/libbobgui/icons/dialog-information-symbolic.svg</property>
                                      </object>
                                    </property>
                                  </object>
                                </property>
                                <signal name="clicked" handler="open_object_details"/>
                              </object>
                            </property>
                          </object>
                        </child>
                        <child>
                          <object class="BobguiStackPage">
                            <property name="name">details</property>
                            <property name="child">
                              <object class="BobguiButton">
                                <property name="focus-on-click">0</property>
                                <property name="tooltip-text" translatable="yes">Show all Objects</property>
                                <property name="halign">center</property>
                                <property name="valign">center</property>
                                <property name="child">
                                  <object class="BobguiImage">
                                    <property name="paintable">
                                      <object class="BobguiSvg" id="view-list-symbolic">
                                        <property name="resource">/org/bobgui/libbobgui/icons/view-list-symbolic.svg</property>
                                      </object>
                                    </property>
                                  </object>
                                </property>
                                <signal name="clicked" handler="close_object_details"/>
                              </object>
                            </property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </child>
            <child>
              <object class="BobguiStackPage">
                <property name="name">global</property>
                <property name="child">
                  <object class="BobguiStack" id="global_button_stack">
                    <property name="visible-child-name" bind-source="global_stack" bind-property="visible-child-name"/>
                    <child>
                      <object class="BobguiStackPage">
                        <property name="name">general</property>
                        <property name="child">
                          <object class="BobguiBox"/>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="BobguiStackPage">
                        <property name="name">visual</property>
                        <property name="child">
                          <object class="BobguiBox"/>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="BobguiStackPage">
                        <property name="name">resources</property>
                        <property name="child">
                          <object class="BobguiStack" id="resource_buttons">
                            <property name="halign">start</property>
                            <property name="valign">center</property>
                            <child>
                              <object class="BobguiStackPage">
                                <property name="name">list</property>
                                <property name="child">
                                  <object class="BobguiButton">
                                    <property name="focus-on-click">0</property>
                                    <property name="tooltip-text" translatable="yes">Show Details</property>
                                    <property name="halign">center</property>
                                    <property name="valign">center</property>
                                    <property name="child">
                                      <object class="BobguiImage">
                                        <property name="paintable">dialog-information-symbolic</property>
                                      </object>
                                    </property>
                                  </object>
                                </property>
                              </object>
                            </child>
                            <child>
                              <object class="BobguiStackPage">
                                <property name="name">details</property>
                                <property name="child">
                                  <object class="BobguiButton">
                                    <property name="focus-on-click">0</property>
                                    <property name="tooltip-text" translatable="yes">Show all Resources</property>
                                    <property name="halign">center</property>
                                    <property name="valign">center</property>
                                    <property name="child">
                                      <object class="BobguiImage">
                                        <property name="paintable">view-list-symbolic</property>
                                      </object>
                                    </property>
                                  </object>
                                </property>
                              </object>
                            </child>
                          </object>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="BobguiStackPage">
                        <property name="name">clipboard</property>
                        <property name="child">
                          <object class="BobguiBox"/>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="BobguiStackPage">
                        <property name="name">statistics</property>
                        <property name="child">
                          <object class="BobguiToggleButton" id="record_statistics_button">
                            <property name="focus-on-click">0</property>
                            <property name="tooltip-text" translatable="yes">Collect Statistics</property>
                            <property name="halign">start</property>
                            <property name="valign">center</property>
                            <property name="child">
                              <object class="BobguiImage">
                                <property name="paintable">
                                  <object class="BobguiSvg">
                                    <property name="resource">/org/bobgui/libbobgui/icons/media-record-symbolic.svg</property>
                                  </object>
                                </property>
                              </object>
                            </property>
                          </object>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="BobguiStackPage">
                        <property name="name">logs</property>
                        <property name="child">
                          <object class="BobguiBox"/>
                        </property>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </child>
            <child>
              <object class="BobguiStackPage">
                <property name="name">css</property>
                <property name="child">
                  <object class="BobguiBox"/>
                </property>
              </object>
            </child>
            <child>
              <object class="BobguiStackPage">
                <property name="name">recorder</property>
                <property name="child">
                  <object class="BobguiBox"/>
                </property>
              </object>
            </child>
          </object>
        </child>
        <child type="title">
          <object class="BobguiStackSwitcher">
            <property name="margin-start">6</property>
            <property name="margin-end">6</property>
            <property name="stack">top_stack</property>
          </object>
        </child>
      </object>
    </property>
    <property name="child">
      <object class="BobguiStack" id="top_stack">
        <child>
          <object class="BobguiStackPage">
            <property name="name">objects</property>
            <property name="title" translatable="yes">Objects</property>
            <property name="child">
              <object class="BobguiStack" id="object_stack">
                <child>
                  <object class="BobguiStackPage">
                    <property name="name">object-tree</property>
                    <property name="child">
                      <object class="BobguiInspectorObjectTree" id="object_tree">
                        <signal name="object-activated" handler="on_object_activated"/>
                        <signal name="object-selected" handler="on_object_selected"/>
                      </object>
                    </property>
                  </object>
                </child>
                <child>
                  <object class="BobguiStackPage">
                    <property name="name">object-details</property>
                    <property name="child">
                      <object class="BobguiBox">
                        <child>
                          <object class="BobguiBox">
                            <property name="orientation">vertical</property>
                            <child>
                              <object class="BobguiCenterBox">
                                <property name="start-widget">
                                  <object class="BobguiBox">
                                    <style>
                                      <class name="toolbar"/>
                                    </style>
                                    <child>
                                      <object class="BobguiToggleButton" id="sidebar_toggle">
                                        <property name="child">
                                          <object class="BobguiImage">
                                            <property name="paintable">
                                              <object class="BobguiSvg">
                                                <property name="resource">/org/bobgui/libbobgui/icons/open-menu-symbolic.svg</property>
                                              </object>
                                            </property>
                                          </object>
                                        </property>
                                        <property name="tooltip-text" translatable="yes">Toggle Sidebar</property>
                                        <property name="active">1</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiStack" id="object_start_stack">
                                        <property name="hhomogeneous">0</property>
                                        <property name="vhomogeneous">0</property>
                                        <child>
                                          <object class="BobguiStackPage">
                                            <property name="name">empty</property>
                                            <property name="child">
                                              <object class="BobguiBox"/>
                                            </property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="BobguiStackPage">
                                            <property name="name">actions</property>
                                            <property name="child">
                                              <object class="BobguiButton" id="refresh_actions_button">
                                                <property name="child">
                                                  <object class="BobguiImage">
                                                    <property name="paintable">
                                                      <object class="BobguiSvg">
                                                        <property name="resource">/org/bobgui/libbobgui/icons/view-refresh-symbolic.svg</property>
                                                      </object>
                                                    </property>
                                                  </object>
                                                </property>
                                                <property name="tooltip-text" translatable="yes">Refresh action state</property>
                                              </object>
                                            </property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="BobguiStackPage">
                                            <property name="name">magnifier</property>
                                            <property name="child">
                                              <object class="BobguiScale">
                                                <property name="width-request">150</property>
                                                <property name="draw-value">0</property>
                                                <property name="adjustment">magnification_adjustment</property>
                                                <marks>
                                                  <mark value="1.0" position="bottom"/>
                                                  <mark value="2.0" position="bottom"/>
                                                  <mark value="3.0" position="bottom"/>
                                                  <mark value="4.0" position="bottom"/>
                                                  <mark value="5.0" position="bottom"/>
                                                </marks>
                                              </object>
                                            </property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </property>
                                <property name="center-widget">
                                  <object class="BobguiStack" id="object_center_stack">
                                    <property name="transition-type">crossfade</property>
                                    <property name="hexpand">1</property>
                                    <property name="halign">center</property>
                                    <property name="hhomogeneous">0</property>
                                    <property name="vhomogeneous">0</property>
                                    <child>
                                      <object class="BobguiStackPage">
                                        <property name="name">title</property>
                                        <property name="child">
                                          <object class="BobguiLabel" id="object_title"/>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiStackPage">
                                        <property name="name">prop-search</property>
                                        <property name="child">
                                          <object class="BobguiSearchEntry" id="prop_search_entry">
                                            <property name="max-width-chars">40</property>
                                            <property name="valign">center</property>
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiStackPage">
                                        <property name="name">layout-prop-search</property>
                                        <property name="child">
                                          <object class="BobguiSearchEntry" id="layout_prop_search_entry">
                                            <property name="max-width-chars">40</property>
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                  </object>
                                </property>
                                <property name="end-widget">
                                  <object class="BobguiBox">
                                    <style>
                                      <class name="toolbar"/>
                                    </style>
                                    <child>
                                      <object class="BobguiButton" id="go_up_button">
                                        <property name="child">
                                          <object class="BobguiImage">
                                            <property name="paintable">
                                              <object class="BobguiSvg">
                                                <property name="resource">/org/bobgui/libbobgui/icons/go-up-symbolic.svg</property>
                                              </object>
                                            </property>
                                          </object>
                                        </property>
                                        <property name="tooltip-text" translatable="yes">Previous object</property>
                                        <signal name="clicked" handler="go_up_cb"/>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiButton" id="go_down_button">
                                        <property name="child">
                                          <object class="BobguiImage">
                                            <property name="paintable">
                                              <object class="BobguiSvg">
                                                <property name="resource">/org/bobgui/libbobgui/icons/go-down-symbolic.svg</property>
                                              </object>
                                            </property>
                                          </object>
                                        </property>
                                        <property name="tooltip-text" translatable="yes">Child object</property>
                                        <signal name="clicked" handler="go_down_cb"/>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiButton" id="go_previous_button">
                                        <property name="child">
                                          <object class="BobguiImage">
                                            <property name="paintable">
                                              <object class="BobguiSvg">
                                                <property name="resource">/org/bobgui/libbobgui/icons/go-previous-symbolic.svg</property>
                                              </object>
                                            </property>
                                          </object>
                                        </property>
                                        <property name="tooltip-text" translatable="yes">Previous sibling</property>
                                        <signal name="clicked" handler="go_previous_cb"/>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiLabel" id="list_position_label">
                                        <property name="tooltip-text" translatable="yes">List Position</property>
                                        <property name="attributes">0 -1 font-features "tnum=1"</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiButton" id="go_next_button">
                                        <property name="child">
                                          <object class="BobguiImage">
                                            <property name="paintable">
                                              <object class="BobguiSvg">
                                                <property name="resource">/org/bobgui/libbobgui/icons/go-next-symbolic.svg</property>
                                              </object>
                                            </property>
                                          </object>
                                        </property>
                                        <property name="tooltip-text" translatable="yes">Next sibling</property>
                                        <signal name="clicked" handler="go_next_cb"/>
                                      </object>
                                    </child>
                                  </object>
                                </property>
                              </object>
                            </child>
                            <child>
                              <object class="BobguiSeparator"/>
                            </child>
                            <child>
                              <object class="BobguiBox">
                                <child>
                                  <object class="BobguiRevealer" id="sidebar_revealer">
                                    <property name="transition-type">slide-right</property>
                                    <property name="reveal-child" bind-source="sidebar_toggle" bind-property="active" bind-flags="sync-create"/>
                                    <child>
                                      <object class="BobguiStackSidebar">
                                        <property name="stack">object_details</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="BobguiStack" id="object_details">
                                    <signal name="notify::visible-child" handler="object_details_changed"/>
                                    <child>
                                      <object class="BobguiStackPage">
                                        <property name="name">misc</property>
                                        <property name="title" translatable="yes">Miscellaneous</property>
                                        <property name="child">
                                          <object class="BobguiInspectorMiscInfo" id="misc_info">
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiStackPage">
                                        <property name="name">properties</property>
                                        <property name="title" translatable="yes">Properties</property>
                                        <property name="child">
                                          <object class="BobguiInspectorPropList" id="prop_list">
                                            <property name="search-entry">prop_search_entry</property>
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiStackPage">
                                        <property name="name">layout_properties</property>
                                        <property name="title" translatable="yes">Layout</property>
                                        <property name="child">
                                          <object class="BobguiInspectorPropList" id="layout_prop_list">
                                            <property name="search-entry">layout_prop_search_entry</property>
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiStackPage">
                                        <property name="name">css-nodes</property>
                                        <property name="title" translatable="yes">CSS Nodes</property>
                                        <property name="child">
                                          <object class="BobguiInspectorCssNodeTree" id="widget_css_node_tree">
                                            <signal name="notify::node" handler="notify_node"/>
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiStackPage">
                                        <property name="name">size-groups</property>
                                        <property name="title" translatable="yes">Size Groups</property>
                                        <property name="child">
                                          <object class="BobguiInspectorSizeGroups" id="size_groups"/>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiStackPage">
                                        <property name="name">data</property>
                                        <property name="title" translatable="yes">Data</property>
                                        <property name="child">
                                          <object class="BobguiInspectorTreeData" id="tree_data"/>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiStackPage">
                                        <property name="name">list-data</property>
                                        <property name="title" translatable="yes">Data</property>
                                        <property name="child">
                                          <object class="BobguiInspectorListData" id="list_data">
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiStackPage">
                                        <property name="name">actions</property>
                                        <property name="title" translatable="yes">Actions</property>
                                        <property name="child">
                                          <object class="BobguiInspectorActions" id="actions">
                                            <property name="button">refresh_actions_button</property>
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiStackPage">
                                        <property name="name">menu</property>
                                        <property name="title" translatable="yes">Menu</property>
                                        <property name="child">
                                          <object class="BobguiInspectorMenu" id="menu"/>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiStackPage">
                                        <property name="name">controllers</property>
                                        <property name="title" translatable="yes">Controllers</property>
                                        <property name="child">
                                          <object class="BobguiInspectorControllers" id="controllers">
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiStackPage">
                                        <property name="name">magnifier</property>
                                        <property name="title" translatable="yes">Magnifier</property>
                                        <property name="child">
                                          <object class="BobguiInspectorMagnifier" id="magnifier">
                                            <property name="adjustment">magnification_adjustment</property>
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiStackPage">
                                        <property name="name">shortcuts</property>
                                        <property name="title" translatable="yes">Shortcuts</property>
                                        <property name="child">
                                          <object class="BobguiInspectorShortcuts" id="shortcuts">
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiStackPage">
                                        <property name="name">a11y</property>
                                        <property name="title" translatable="yes">Accessibility</property>
                                        <property name="child">
                                          <object class="BobguiInspectorA11y" id="a11y">
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="BobguiStackPage">
                                        <property name="name">svg</property>
                                        <property name="title" translatable="yes">SVG</property>
                                        <property name="child">
                                          <object class="BobguiInspectorSvg" id="svg">
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </child>
        <child>
          <object class="BobguiStackPage">
            <property name="name">global</property>
            <property name="title" translatable="yes">Global</property>
            <property name="child">
              <object class="BobguiBox">
                <child>
                  <object class="BobguiStackSidebar">
                    <property name="stack">global_stack</property>
                  </object>
                </child>
                <child>
                  <object class="BobguiStack" id="global_stack">
                    <child>
                      <object class="BobguiStackPage">
                        <property name="name">general</property>
                        <property name="title" translatable="yes">Information</property>
                        <property name="child">
                          <object class="BobguiInspectorGeneral" id="general"/>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="BobguiStackPage">
                        <property name="name">visual</property>
                        <property name="title" translatable="yes">Settings</property>
                        <property name="child">
                          <object class="BobguiInspectorVisual" id="visual"/>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="BobguiStackPage">
                        <property name="name">resources</property>
                        <property name="title" translatable="yes">Resources</property>
                        <property name="child">
                          <object class="BobguiInspectorResourceList">
                            <property name="buttons">resource_buttons</property>
                          </object>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="BobguiStackPage">
                        <property name="name">clipboard</property>
                        <property name="title" translatable="yes">Clipboard</property>
                        <property name="child">
                          <object class="BobguiInspectorClipboard" id="clipboard">
                          </object>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="BobguiStackPage">
                        <property name="name">statistics</property>
                        <property name="title" translatable="yes">Statistics</property>
                        <property name="child">
                          <object class="BobguiInspectorStatistics">
                            <property name="button">record_statistics_button</property>
                          </object>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="BobguiStackPage">
                        <property name="name">logs</property>
                        <property name="title" translatable="yes">Logging</property>
                        <property name="child">
                          <object class="BobguiInspectorLogs" id="logs"/>
                        </property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </child>
        <child>
          <object class="BobguiStackPage">
            <property name="name">css</property>
            <property name="title" translatable="yes">CSS</property>
            <property name="child">
              <object class="BobguiInspectorCssEditor" id="css_editor"/>
            </property>
          </object>
        </child>
        <child>
          <object class="BobguiStackPage">
            <property name="name">recorder</property>
            <property name="title" translatable="yes">Recorder</property>
            <property name="child">
              <object class="BobguiInspectorRecorder" id="widget_recorder">
                <signal name="notify::debug-nodes" handler="force_full_redraw" swapped='true'/>
              </object>
            </property>
          </object>
        </child>
      </object>
    </property>
  </template>
</interface>
