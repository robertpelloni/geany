<?xml version="1.0" encoding="UTF-8"?>
<interface domain="bobgui40">
  <object class="BobguiAdjustment" id="time_adjustment">
    <property name="upper">10</property>
    <property name="step-increment">1</property>
    <property name="page-increment">10</property>
    <signal name="value-changed" handler="time_adjustment_changed" object="BobguiMediaControls" swapped="no"/>
  </object>
  <object class="BobguiAdjustment" id="volume_adjustment">
    <property name="upper">1</property>
    <property name="step-increment">0.1</property>
    <property name="page-increment">1</property>
    <property name="value">1</property>
    <signal name="value-changed" handler="volume_adjustment_changed" object="BobguiMediaControls" swapped="no"/>
  </object>
  <template class="BobguiMediaControls" parent="BobguiWidget">
    <child>
      <object class="BobguiBox" id="box">
        <property name="sensitive">0</property>
        <property name="spacing">6</property>
        <child>
          <object class="BobguiButton" id="play_button">
            <property name="receives-default">1</property>
            <property name="halign">3</property>
            <property name="valign">3</property>
            <property name="has-frame">0</property>
            <property name="icon-name">media-playback-start-symbolic</property>
            <property name="tooltip-text" context="media controls tooltip" translatable="yes">Play</property>
            <signal name="clicked" handler="play_button_clicked" object="BobguiMediaControls" swapped="no"/>
          </object>
        </child>
        <child>
          <object class="BobguiBox" id="time_box">
            <child>
              <object class="BobguiLabel" id="time_label">
                <property name="attributes">0 -1 font-features "tnum=1"</property>
              </object>
            </child>
            <child>
              <object class="BobguiScale" id="seek_scale">
                <property name="adjustment">time_adjustment</property>
                <property name="restrict-to-fill-level">0</property>
                <property name="hexpand">1</property>
                <accessibility>
                  <property name="label" translatable="yes" context="media controls">Position</property>
                </accessibility>
              </object>
            </child>
            <child>
              <object class="BobguiLabel" id="duration_label">
                <property name="attributes">0 -1 font-features "tnum=1"</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="BobguiVolumeButton" id="volume_button">
            <property name="adjustment">volume_adjustment</property>
            <property name="valign">center</property>
            <accessibility>
              <property name="label" translatable="yes" context="media controls">Volume</property>
            </accessibility>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
