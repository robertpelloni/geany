#define WIN32_LEAN_AND_MEAN
#include <windows.h>

BOBGUI_ICON		ICON			"bobgui.ico"

VS_VERSION_INFO VERSIONINFO
  FILEVERSION @BOBGUI_MAJOR_VERSION@,@BOBGUI_MINOR_VERSION@,@BOBGUI_MICRO_VERSION@,0
  PRODUCTVERSION @BOBGUI_MAJOR_VERSION@,@BOBGUI_MINOR_VERSION@,@BOBGUI_MICRO_VERSION@,0
  FILEFLAGSMASK 0
  FILEFLAGS 0
  FILEOS VOS__WINDOWS32
  FILETYPE VFT_DLL
  FILESUBTYPE VFT2_UNKNOWN
  BEGIN
    BLOCK "StringFileInfo"
    BEGIN
      BLOCK "040904B0"
      BEGIN
	VALUE "CompanyName", "The BOBGUI developer community"
	VALUE "FileDescription", "GIMP Toolkit"
	VALUE "FileVersion", "@BOBGUI_VERSION@.0"
	VALUE "InternalName", "libbobgui-win32-@BOBGUI_API_VERSION@"
	VALUE "LegalCopyright", "Copyright (C) 1995-1997 Peter Mattis, Spencer Kimball and Josh MacDonald. Modified by the BOBGUI+ Team and others 1997-2011."
	VALUE "OriginalFilename", "libbobgui-win32-@BOBGUI_API_VERSION@.dll"
	VALUE "ProductName", "BOBGUI+"
	VALUE "ProductVersion", "@BOBGUI_VERSION@"
      END
    END
    BLOCK "VarFileInfo"
    BEGIN
      VALUE "Translation", 0x409, 1200
    END
  END

ISOLATIONAWARE_MANIFEST_RESOURCE_ID RT_MANIFEST libbobgui.manifest
