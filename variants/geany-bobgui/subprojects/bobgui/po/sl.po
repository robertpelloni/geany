msgid "libEGL not available in this sandbox"
msgstr "Sandbox ne podpira knjižnice libEGL"

#: gdk/gdkdisplay.c:1865
msgid "libEGL not available"
msgstr "Knjižnica libEL ni na voljo"

#: gdk/gdkdisplay.c:1875
