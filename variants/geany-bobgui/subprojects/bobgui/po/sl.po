#, c-format
msgid "Trying to use %s, but it is disabled via GDK_DISABLE"
msgstr "Poskus uporabe %s, vendar je onemogočeno prek GDK_DISABLE"

#: gdk/gdktexture.c:646
msgid "Unknown image format."
msgstr "Neznan zapis slike."

