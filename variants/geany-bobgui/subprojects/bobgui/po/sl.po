msgstr[0] "Vstavku EGL manjka %2$d razširitev: %1$s"
msgstr[1] "Vstavku EGL manjka %2$d razširitev: %1$s"
msgstr[2] "Vstavku EGL manjkata %2$d razširitvi: %1$s"
msgstr[3] "Vstavku EGL manjkajo %2$d razširitve: %1$s"

