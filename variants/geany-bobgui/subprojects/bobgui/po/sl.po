msgstr "Ni mogoče začeti zaslona EGL"

#: gdk/gdkdisplay.c:1894
#, c-format
msgid "EGL version %d.%d is too old. BOBGUI requires %d.%d"
msgstr "Različica EGL %d.%d je prestara, Oklje BOBGUI zahteva različico %d.%d"

