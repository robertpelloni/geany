msgstr "შემცველობის \"%s\"-ად გამოტანა შეუძლებელია"

#: gdk/gdkcontentprovider.c:127
#, c-format
msgid "Cannot provide contents as %s"
msgstr "შემცველობის %s-ად გამოტანა შეუძლებელია"

#: gdk/gdkdisplay.c:176 gdk/gdkglcontext.c:472
msgid "The current backend does not support OpenGL"
