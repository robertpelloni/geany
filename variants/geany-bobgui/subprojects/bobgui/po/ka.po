#: gdk/gdkglcontext.c:1436
msgid "OpenGL ES API disabled via GDK_DISABLE"
msgstr "OpenGL ES API გამორთულია GDK_DISABLE-ის საშუალებით"

#: gdk/gdkglcontext.c:1448
msgid "OpenGL API disabled via GDK_DISABLE"
