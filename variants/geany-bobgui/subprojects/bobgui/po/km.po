#. *
#. * SECTION:bobguifilechooserbutton
#. * @Short_description: A button to launch a file selection dialog
#. * @Title: BobguiFileChooserButton
#. * @See_also:#BobguiFileChooserDialog
#. *
#. * The #BobguiFileChooserButton is a widget that lets the user select a
#. * file.  It implements the #BobguiFileChooser interface.  Visually, it is a
#. * file name with a button to bring up a #BobguiFileChooserDialog.
#. * The user can then use that dialog to change the file associated with
#. * that button.  This widget does not support setting the
#. * #BobguiFileChooser:select-multiple property to %TRUE.
#. *
#. * <example>
#. * <title>Create a button to let the user select a file in /etc</title>
#. * <programlisting>
#. * {
#. *   BobguiWidget *button;
#. *
#. *   button = bobgui_file_chooser_button_new (_("Select a file"),
#. *                                         BOBGUI_FILE_CHOOSER_ACTION_OPEN);
#. *   bobgui_file_chooser_set_current_folder (BOBGUI_FILE_CHOOSER (button),
#. *                                        "/etc");
#. * }
#. * </programlisting>
#. * </example>
#. *
#. * The #BobguiFileChooserButton supports the #BobguiFileChooserAction<!-- -->s
#. * %BOBGUI_FILE_CHOOSER_ACTION_OPEN and %BOBGUI_FILE_CHOOSER_ACTION_SELECT_FOLDER.
#. *
#. * <important>
#. * The #BobguiFileChooserButton will ellipsize the label,
#. * and thus will thus request little horizontal space.  To give the button
#. * more space, you should call bobgui_widget_get_preferred_size(),
#. * bobgui_file_chooser_button_set_width_chars(), or pack the button in
#. * such a way that other interface elements give space to the widget.
#. * </important>
#.
#. **************** *
#. *  Private Macros  *
#. * ****************
#: ../bobgui/bobguifilechooserbutton.c:104
msgid "Select a File"
msgstr "бһҮбҹ’бһҡбһҫбһҹвҖӢбһҜбһҖбһҹбһ¶бһҡ"

