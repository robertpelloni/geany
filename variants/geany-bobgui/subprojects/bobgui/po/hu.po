#: gdk/gdkdisplay.c:1365 gdk/gdkvulkancontext.c:1966
msgid "Vulkan support disabled via GDK_DISABLE"
msgstr "A Vulkan támogatás letiltva a GDK_DISABLE beállításon keresztül"

