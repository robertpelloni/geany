#: gdk/win32/gdkglcontext-win32-wgl.c:783 gdk/x11/gdkglcontext-glx.c:700
msgid "Unable to create a GL context"
msgstr "Nem lehet létrehozni GL környezetet"

#: gdk/gdkglcontext.c:1440
msgid "OpenGL ES API disabled via GDK_DISABLE"
msgstr "Az OpenGL ES API letiltva a GDK_DISABLE beállításon keresztül"

#: gdk/gdkglcontext.c:1452
msgid "OpenGL API disabled via GDK_DISABLE"
msgstr "Az OpenGL API letiltva a GDK_DISABLE beállításon keresztül"

#: gdk/gdkglcontext.c:1463
#, c-format
msgid "Application does not support %s API"
msgstr "Az alkalmazás nem támogatja a(z) %s API-t"

#. translators: This is about OpenGL backend names, like
#. * "Trying to use X11 GLX, but EGL is already in use"
#.
#: gdk/gdkglcontext.c:2259
#, c-format
msgid "Trying to use %s, but %s is already in use"
msgstr "A(z) %s használatának kísérlete, de a(z) %s már használatban van"

#: gdk/gdkglcontext.c:2270
#, c-format
msgid "Trying to use %s, but it is disabled via GDK_DISABLE"
msgstr ""
"A(z) %s használatának kísérlete, de le van tiltva a GDK_DISABLE beállításon "
"keresztül"

#: gdk/gdktexture.c:646
msgid "Unknown image format."
msgstr "Ismeretlen képformátum."

