#: gdk/gdkdisplay.c:1865
msgid "libEGL not available in this sandbox"
msgstr "libEGL tidak tersedia di sandbox ini"

#: gdk/gdkdisplay.c:1866
msgid "libEGL not available"
msgstr "libEGL tidak tersedia"

