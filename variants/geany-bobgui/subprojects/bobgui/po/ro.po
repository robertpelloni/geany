msgstr "Nu se pot lua date DnD. GlobalLock(0x%p) a eșuat: 0x%lx."

#: gdk/win32/gdkdrop-win32.c:950
#, c-format
msgid "Cannot get DnD data. GlobalSize(0x%p) failed: 0x%lx."
