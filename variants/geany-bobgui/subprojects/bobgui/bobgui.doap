<?xml version="1.0" encoding="UTF-8"?>
<Project xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:foaf="http://xmlns.com/foaf/0.1/"
         xmlns:gnome="http://api.gnome.org/doap-extensions#"
         xmlns="http://usefulinc.com/ns/doap#">

  <name xml:lang="en">bobgui</name>
  <shortname>bobgui</shortname>
  <shortdesc xml:lang="en">Multi-platform toolkit</shortdesc>
  <description xml:lang="en">BOBGUI is a multi-platform toolkit for creating graphical user
interfaces. Offering a complete set of widgets, BOBGUI is suitable for
projects ranging from small one-off tools to complete application
suites.

BOBGUI has been designed from the ground up to support a range of
languages, not only C/C++. Using BOBGUI from languages such as Perl and
Python (especially in combination with the Glade GUI builder) provides
an effective method of rapid application development.

BOBGUI is free software and part of the GNU Project. However, the
licensing terms for BOBGUI, the GNU LGPL, allow it to be used by all
developers, including those developing proprietary software, without
any license fees or royalties.</description>
  <homepage rdf:resource="http://www.bobgui.io/" />
  <license rdf:resource="http://usefulinc.com/doap/licenses/lgpl" />
  <bug-database rdf:resource="https://github.com/robertpelloni/bobgui/issues/" />
  <download-page rdf:resource="https://github.com/robertpelloni/bobgui/releases/" />
  <developer-forum rdf:resource="https://github.com/robertpelloni/bobgui/discussions" />
  <category rdf:resource="http://api.gnome.org/doap-extensions#core" />

  <programming-language>C</programming-language>
  <programming-language>C++</programming-language>

  <repository>
    <GitRepository>
        <browse rdf:resource="https://github.com/robertpelloni/bobgui/"/>
      <location rdf:resource="https://github.com/robertpelloni/bobgui.git"/>
    </GitRepository>
  </repository>

