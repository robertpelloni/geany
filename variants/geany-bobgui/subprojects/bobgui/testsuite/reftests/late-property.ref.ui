<interface>
  <object class="BobguiWindow">
    <child type="titlebar">
      <object class="BobguiHeaderBar">
        <property name="title-widget">
          <object class="BobguiLabel">
            <property name="label">Title widget</property>
          </object>
        </property>
        <child type="start">
          <object class="BobguiButton">
            <property name="label">Button</property>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
