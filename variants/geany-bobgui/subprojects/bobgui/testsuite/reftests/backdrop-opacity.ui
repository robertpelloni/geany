<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <object class="BobguiWindow">
    <property name="decorated">false</property>
    <property name="child">
      <object class="BobguiBox">
        <child>
          <object class="BobguiLabel">
            <property name="name">opacity-property</property>
          </object>
        </child>
        <child>
          <object class="BobguiLabel">
            <property name="name">opacity-backdrop-filter</property>
          </object>
        </child>
        <child>
          <object class="BobguiLabel">
            <property name="name">both</property>
          </object>
        </child>
        <child>
          <object class="BobguiLabel">
            <property name="name">opacity-filter</property>
          </object>
        </child>
        <child>
          <object class="BobguiLabel">
            <property name="name">opacity-widget</property>
            <property name="opacity">0.4</property>
          </object>
        </child>
      </object>
    </property>
</object>
