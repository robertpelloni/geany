<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <object class="BobguiWindow" id="window1">
    <property name="height_request">500</property>
    <property name="width_request">500</property>
    <property name="decorated">0</property>
    <child>
      <object class="BobguiBox" id="box1">
        <property name="orientation">vertical</property>
        <child>
          <object class="BobguiPaned" id="paned1">
            <property name="shrink-start-child">0</property>
            <property name="resize-start-child">0</property>
            <property name="position_set">1</property>
            <child>
              <object class="BobguiCheckButton" id="checkbutton1">
                <child>
                  <object class="BobguiLabel" id="label1">
                    <property name="label" translatable="yes">Hello
World</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="BobguiBox" id="box2">
                <property name="orientation">vertical</property>
                <child>
                  <placeholder/>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="BobguiPaned" id="paned2">
            <property name="shrink-start-child">0</property>
            <property name="resize-start-child">0</property>
            <property name="position_set">1</property>
            <child>
              <object class="BobguiCheckButton" id="radiobutton1">
                <property name="active">1</property>
                <child>
                  <object class="BobguiLabel" id="label2">
                    <property name="label" translatable="yes">Hello
World</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="BobguiBox" id="box3">
                <property name="orientation">vertical</property>
                <child>
                  <placeholder/>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="BobguiPaned" id="paned3">
            <property name="shrink-start-child">0</property>
            <property name="resize-start-child">0</property>
            <property name="position_set">1</property>
            <child>
              <object class="BobguiToggleButton" id="togglebutton1">
                <property name="receives_default">1</property>
                <child>
                  <object class="BobguiLabel" id="label3">
                    <property name="label" translatable="yes">Hello
World</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="BobguiBox" id="box4">
                <property name="orientation">vertical</property>
                <child>
                  <placeholder/>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="BobguiPaned" id="paned4">
            <property name="shrink-start-child">0</property>
            <property name="resize-start-child">0</property>
            <property name="position_set">1</property>
            <child>
              <object class="BobguiButton" id="button1">
                <property name="receives_default">1</property>
                <child>
                  <object class="BobguiLabel" id="label4">
                    <property name="label" translatable="yes">Hello
World</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="BobguiBox" id="box5">
                <property name="orientation">vertical</property>
                <child>
                  <placeholder/>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
