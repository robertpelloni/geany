<!-- check that an invisible child does not influence the layout -->
<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <object class="BobguiWindow" id="window_information_collection">
    <property name="decorated">0</property>
    <child>
      <object class="BobguiBox" id="box1">
        <child>
          <object class="BobguiLabel" id="label1">
            <property name="label" translatable="yes">Hello, Hello</property>
          </object>
        </child>
        <child>
          <object class="BobguiLabel" id="label2">
            <property name="label" translatable="yes">cruel</property>
          </object>
        </child>
        <child>
          <object class="BobguiLabel" id="label3">
            <property name="label" translatable="yes">World</property>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
